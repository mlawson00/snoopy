# Public app URL used for auth callbacks and canonical links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase production workspace persistence.
# Without these plus SNOOPY_DEFAULT_WORKSPACE_ID, run APIs use a development/session fallback.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SNOOPY_DEFAULT_WORKSPACE_ID=

# PostHog browser analytics.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=

# LLM-powered customer-owned agent generation.
# Local Gemma is the primary development runtime for agent generation and internal agent reactions.
GEMMA_OPENAI_BASE_URL=http://gemma31b-llamacpp:8080/v1
GEMMA_OPENAI_API_KEY=local-llama
GEMMA_OPENAI_MODEL=gemma-4-31B-it-UD-Q4_K_XL.gguf
# Set to 1 only for deterministic smoke tests or local debugging.
SNOOPY_DISABLE_GEMMA=

# Legacy/secondary hosted model path.
# Without model credentials, the generator returns a deterministic usable profile for development and demos.
OPENAI_API_KEY=
OPENAI_AGENT_GENERATOR_MODEL=gpt-5.4-mini

# Local Gemma OpenAI-compatible endpoint for the Codex workbench.
LLAMACPP_GEMMA31B_HOST_PORT=8006
LLAMACPP_GEMMA31B_MODEL_DIR=/home/mike/Desktop/llama-cpp-models/gemma-4-31B-it-GGUF
LLAMACPP_GEMMA31B_MODEL_FILE=gemma-4-31B-it-UD-Q4_K_XL.gguf
LLAMACPP_GEMMA31B_API_KEY=local-llama
LLAMACPP_GEMMA31B_TEMP=1.0
LLAMACPP_GEMMA31B_TOP_P=0.95
LLAMACPP_GEMMA31B_TOP_K=64
LLAMACPP_GEMMA31B_CTX_SIZE=655360
LLAMACPP_GEMMA31B_PARALLEL=3

# Billing shell.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Browser validation and self-audit defaults.
PLAYWRIGHT_HEADLESS=true
SNOOPY_SELF_AUDIT_BASE_URL=http://127.0.0.1:3000
